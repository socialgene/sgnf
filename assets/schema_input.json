{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "https://raw.githubusercontent.com/socialgene/sgnf/master/assets/schema_input.json",
    "title": "socialgene/sgnf pipeline - params.input schema",
    "description": "Schema for the file provided with params.input",
    "type": "array",
    "items": {
        "type": "object",
        "properties": {
            "fasta": {
                "type": "string",
                "format": "file-path",
                "pattern": "^\\S+\\.f(a|asta|na|as)\\.gz$",
                "errorMessage": "Path to a FASTA file, cannot contain spaces",
                "exists": true
            },
            "gbff": {
                "type": "string",
                "format": "file-path",
                "pattern": "^\\S+\\.gbff\\.gz$",
                "errorMessage": "Path to a GenBank file ('.gbff'), cannot contain spaces",
                "exists": true
            }
        },
        "required": [
            "sample",
            "fasta"
        ]
    }
}
